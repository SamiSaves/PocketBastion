# opencode.env.example — template for the OpenCode server environment.
#
# Copy this onto the VM's persistent state disk (NEVER commit the real file):
#   scp config/opencode.env.example core@10.44.0.1:/tmp/opencode.env
#   ssh core@10.44.0.1 'install -m 0600 /tmp/opencode.env /mnt/state/secrets/opencode.env && rm /tmp/opencode.env'
#   ssh core@10.44.0.1 'systemctl --user restart opencode.service'
#
# The opencode.container reads it via EnvironmentFile=-/mnt/state/secrets/opencode.env
# (optional — the server starts without it, but has no provider/model until set).

# --- Server access (HTTP basic auth) -----------------------------------------
# Protects the server even inside the VPN. Username defaults to "opencode".
OPENCODE_SERVER_PASSWORD=change-me
# OPENCODE_SERVER_USERNAME=opencode

# --- LLM provider credentials -------------------------------------------------
# Set only the provider(s) you use. These are secrets — keep them off git.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
