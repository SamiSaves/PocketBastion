# Custom OpenCode image.
#
# The official ghcr.io/anomalyco/opencode image is Alpine (musl); OpenCode's
# terminal loads a glibc-only native PTY library (needs gnu_get_libc_version),
# so the integrated terminal is broken on musl. We build on node:24-slim
# (Debian/glibc) instead, which fixes the terminal and avoids other musl
# papercuts. node/npm are handy for the agent's own tooling.
FROM docker.io/library/node:24-slim

RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      git openssh-client ca-certificates \
 && rm -rf /var/lib/apt/lists/* \
 && npm install -g opencode-ai \
 && npm cache clean --force

ENTRYPOINT ["opencode"]
