# deploy.env.example — copy to deploy.env (gitignored) and edit.
# Public keys only, no secrets. Baked into the Ignition config at render time.

# ── SSH access ────────────────────────────────────────────────────────────────
# Your SSH PUBLIC key, added to the core user for login over the tunnel.
# e.g. contents of ~/.ssh/id_ed25519.pub, or make a dedicated key:
#   ssh-keygen -t ed25519 -f ~/.ssh/opencode -C opencode
SSH_AUTHORIZED_KEY="REPLACE_ME ssh-ed25519 AAAA... you@host"

# ── WireGuard bootstrap peer ──────────────────────────────────────────────────
# Your device's WireGuard PUBLIC key (generate the keypair ON the device, see
# README). Seeds peer #0 so the tunnel is up on first boot, before SSH exists.
WG_BOOTSTRAP_PUBKEY=REPLACE_ME

# VPN IP for that bootstrap peer (laptop = .2 per the address plan).
WG_BOOTSTRAP_IP=10.44.0.2

# ── Git commit identity ─────────────────────────────────────────────
# Required before the VM can commit (git refuses without name + email).
GIT_USER_NAME=
GIT_USER_EMAIL=
