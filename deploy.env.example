# deploy.env.example — copy to deploy.env and edit.
#
# Baked into the DigitalOcean Ignition at render time (make ignition-do).
# These are NON-secret: a WireGuard PUBLIC key and a VPN IP.
#
#   cp deploy.env.example deploy.env
#   $EDITOR deploy.env
#   make ignition-do && make tf-apply
#
# deploy.env is gitignored; this .example is the tracked template.

# Your laptop's WireGuard PUBLIC key. Generate the keypair ON the device (see
# the README "Connecting over WireGuard" section) and paste only the PUBLIC key.
# This seeds peer #0 so the tunnel is up on first boot, before SSH exists.
WG_BOOTSTRAP_PUBKEY=REPLACE_ME

# VPN IP for that bootstrap peer (laptop = .2 per the address plan).
WG_BOOTSTRAP_IP=10.44.0.2
