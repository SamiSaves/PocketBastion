# deploy.env.example — copy to deploy.env (gitignored) and edit.
# Public keys only, no secrets. Baked into the Ignition config at render time.
# See the README for how to generate these keys.

# ── SSH access ────────────────────────────────────────────────────────────────
# Your SSH PUBLIC key — lets you log in over the tunnel.
SSH_AUTHORIZED_KEY="REPLACE_ME ssh-ed25519 AAAA... you@host"

# ── WireGuard bootstrap peer ──────────────────────────────────────────────────
# Your device's WireGuard PUBLIC key. Seeds peer #0 so the tunnel is up on first
# boot, before SSH exists.
WG_BOOTSTRAP_PUBKEY=REPLACE_ME

# This device's VPN address — any unique address in 10.44.0.0/24 (server is .1).
WG_BOOTSTRAP_IP=10.44.0.2

# ── Git commit identity ─────────────────────────────────────────────
# Required before the VM can commit (git refuses without name + email).
GIT_USER_NAME=
GIT_USER_EMAIL=

# ── Dev-server ports ──────────────────────────────────────────────────────────
# Space-separated ports/ranges to publish on the tunnel for your dev servers.
# The OpenCode UI (4096) is always published; add whatever your apps need, e.g.
#   OPENCODE_EXTRA_PORTS="3000 5173 8000-8010"
OPENCODE_EXTRA_PORTS=

# ── Memory guardrails ─────────────────────────────────────────────────────────
# All optional; leave empty on larger hosts. Tuned examples are for a 2 GB box.
# Cap the (untrusted) OpenCode container so a runaway dev server is OOM-killed
# inside it instead of freezing the host — sshd + WireGuard stay alive and it
# auto-restarts. MEMORY_SWAP > MEMORY_MAX allows some (zram) swap headroom.
#   OPENCODE_MEMORY_MAX=1400m
#   OPENCODE_MEMORY_SWAP=1900m
OPENCODE_MEMORY_MAX=
OPENCODE_MEMORY_SWAP=
# Compressed RAM swap (no disk wear). A number is MiB; e.g. 2048 or an
# expression like "min(ram, 4096)".
#   ZRAM_SIZE=2048
ZRAM_SIZE=
# On-disk swapfile on the droplet's local SSD (/var/swapfile), as a backstop.
#   SWAPFILE_SIZE=2g
SWAPFILE_SIZE=
