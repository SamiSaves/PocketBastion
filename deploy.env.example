# deploy.env.example — copy to deploy.env and edit.
#
#   cp deploy.env.example deploy.env
#   $EDITOR deploy.env
#
# Everything here is baked into the Ignition config at render time
# (make local-up / make ignition-do). None of these are secret: an SSH PUBLIC
# key and a WireGuard PUBLIC key. Private keys never live in this repo.
#
# deploy.env is gitignored; this .example is the tracked template.

# ── SSH access ────────────────────────────────────────────────────────────────
# Your SSH PUBLIC key, added to the core user so you can log in over the tunnel.
# Paste the full contents of your .pub file (e.g. ~/.ssh/id_ed25519.pub). To
# create a dedicated key:  ssh-keygen -t ed25519 -f ~/.ssh/opencode -C opencode
SSH_AUTHORIZED_KEY="REPLACE_ME ssh-ed25519 AAAA... you@host"

# ── WireGuard bootstrap peer ──────────────────────────────────────────────────
# Your device's WireGuard PUBLIC key. Generate the keypair ON the device (see
# the README) and paste only the PUBLIC key. This seeds peer #0 so the tunnel is
# up on first boot, before SSH exists.
WG_BOOTSTRAP_PUBKEY=REPLACE_ME

# VPN IP for that bootstrap peer (laptop = .2 per the address plan).
WG_BOOTSTRAP_IP=10.44.0.2
