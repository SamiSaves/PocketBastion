# wg0.conf.tmpl — WireGuard server config template (documentation reference).
#
# The actual wg0.conf is rendered at first boot by /usr/local/sbin/wg-setup.sh
# using the server private key from /mnt/state/wireguard/server_private.key.
# Peers are appended from /mnt/state/wireguard/peers.conf (managed by wg-add-peer.sh).
#
# VPN subnet: 10.44.0.0/24
#   server:  10.44.0.1
#   laptop:  10.44.0.2
#   desktop: 10.44.0.3
#   phone:   10.44.0.4

[Interface]
Address    = 10.44.0.1/24
ListenPort = 51820
PrivateKey = {{ WG_PRIVATE_KEY }}

# PostUp/PostDown for firewalld are omitted — FCOS does not ship firewall-cmd.
# Firewall rules will be managed via nftables in Phase 6.

# ── Peers appended from /mnt/state/wireguard/peers.conf at boot ─────────────
# Each peer block looks like:
#
# [Peer]
# # laptop
# PublicKey  = <client public key>
# AllowedIPs = 10.44.0.2/32
