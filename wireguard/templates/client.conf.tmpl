# client.conf.tmpl — WireGuard client config template (documentation reference).
#
# Rendered by scripts/wg-render-client.sh on the host. Variables:
#   {{ CLIENT_PRIVATE_KEY }}  — from secrets/wireguard/<peer>.private
#   {{ CLIENT_ADDRESS }}      — client VPN IP (e.g. 10.44.0.2/24)
#   {{ SERVER_PUBLIC_KEY }}   — from secrets/wireguard/server.public
#   {{ SERVER_ENDPOINT }}     — <vm-ip>:51820 for local; DNS:51820 for DigitalOcean
#
# VPN subnet: 10.44.0.0/24 (split tunnel — only VPN traffic goes through)

[Interface]
Address    = {{ CLIENT_ADDRESS }}
PrivateKey = {{ CLIENT_PRIVATE_KEY }}
DNS        = 10.44.0.1

[Peer]
PublicKey           = {{ SERVER_PUBLIC_KEY }}
Endpoint            = {{ SERVER_ENDPOINT }}
AllowedIPs          = 10.44.0.0/24
PersistentKeepalive = 25
